# Copy to .env if your API is not at http://localhost:5000/api
# Value must include the /api suffix (see src/utils/api.ts).
# If you run the API with npm run api:5001 (port 5001), use:
# VITE_API_URL=http://localhost:5001/api
# For production, set to your deployed API, e.g. https://api.example.com/api
VITE_API_URL=http://localhost:5000/api
