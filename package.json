{
  "name": "house-rental-wpa",
  "private": true,
  "description": "Run npm scripts from this folder; the app lives in /frontend",
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "dev": "npm run dev --prefix frontend",
    "api": "npm run dev --prefix backend",
    "api:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/stop-api-port.ps1",
    "api:5001": "npm run dev:5001 --prefix backend",
    "start:api": "npm start --prefix backend",
    "start": "npm start --prefix frontend",
    "build": "npm run build --prefix frontend",
    "test": "npm test --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "preview": "npm run preview --prefix frontend",
    "docker:build:backend": "docker build -t renatalwpa-backend ./backend",
    "docker:build:frontend": "docker build -t renatalwpa-frontend --build-arg VITE_API_URL=http://localhost:5000/api ./frontend",
    "docker:run:backend": "docker run --rm -p 5000:5000 --env-file backend/.env renatalwpa-backend",
    "docker:run:frontend": "docker run --rm -p 8080:80 renatalwpa-frontend"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "cors": "^2.8.6",
    "docker": "^1.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.11.0",
    "mongoose": "^9.5.0",
    "morgan": "^1.10.1",
    "react": "^19.2.5",
    "react-hot-toast": "^2.6.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.14.2",
    "socket.io": "^4.8.3"
  }
}
