PORT=5000
# If "Port 5000 is already in use", either stop the other Node process or set PORT=5001 and VITE_API_URL=http://localhost:5001/api in frontend/.env
NODE_ENV=development

# --- MongoDB: choose ONE approach ---

# If you use Atlas only (no local Docker), set this so the API never switches to localhost on errors:
# MONGODB_DISABLE_DEV_FALLBACK=true

# A) Local Docker (RenatalWPA: npm run db:up)
# MONGODB_URI=mongodb://127.0.0.1:27017/house_rental

# B) Atlas — full connection string (encode @ in password as %40)
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/house_rental?appName=Cluster0

# C) Atlas — username + password (composed by server)
# Default: mongodb+srv:// (SRV DNS — required for cluster0.*.hostnames; they usually have no A record).
# MONGODB_USER=myAtlasUser
# MONGODB_PASSWORD=mySecretPassword
# MONGODB_CLUSTER_HOST=cluster0.xxxxx.mongodb.net
# MONGODB_DB_NAME=house_rental
# MONGODB_APP_NAME=Cluster0
# MONGODB_CLUSTER_PORT=27017
# MONGODB_USE_SRV=false
# Public DNS (8.8.8.8) is default for Atlas SRV — set false to use system DNS only
# MONGODB_USE_PUBLIC_DNS=false
#
# Cloudflare WARP: if nslookup cluster0....mongodb.net shows "connectivity-check.warp-svc" or 127.0.2.x,
# Atlas cannot connect — pause WARP or exclude *.mongodb.net, or use local Docker Mongo (see README).

# If mongodb+srv fails with querySrv ECONNREFUSED (DNS blocked on some networks):
# - In Atlas → Connect → Drivers: copy the connection string that starts with mongodb:// (standard, not +srv), set as MONGODB_URI, comment MONGODB_USER/PASSWORD; OR
# - MONGODB_DISABLE_DEV_FALLBACK=true (no silent switch to local Mongo; fix DNS or use standard URI)
# MONGODB_DISABLE_DEV_FALLBACK=true

# JWT — placeholder values below are INVALID when NODE_ENV=production (server will exit).
JWT_SECRET=your_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production_2024
JWT_REFRESH_EXPIRE=30d

# Admin default credentials (created by seeder)
ADMIN_EMAIL=admin@houserental.com
ADMIN_PASSWORD=admin123

# Email — required for verification codes & password reset by mail (Gmail: use an App Password, not your normal password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=YENE BET <your_email@gmail.com>

# CORS — must match your Vite dev server
FRONTEND_URL=http://localhost:5173

# --- M-Pesa (Safaricom Ethiopia sandbox / production) — optional ---
# If any of these are missing, premium "upgrade" stays simulated (instant success).
# STK callback must be a public HTTPS URL (use ngrok/localtunnel for local dev).
# MPESA_BASE_URL=https://apisandbox.safaricom.et
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_SHORTCODE=
# MPESA_PASSKEY=
# MPESA_CALLBACK_URL=https://YOUR_PUBLIC_HOST/api/premium/mpesa/callback
# MPESA_PHONE_COUNTRY=251
# MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
# PREMIUM_AMOUNT=500
# PREMIUM_DAYS=30
